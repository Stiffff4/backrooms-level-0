{
  "name": "backrooms-level-0-threshold",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "assets:generate": "node --experimental-strip-types tools/generate-assets/generate.ts --write",
    "assets:check": "node --experimental-strip-types tools/generate-assets/generate.ts --check",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "analyze:build": "node --experimental-strip-types tools/analyze-build/analyze.ts --dir dist",
    "build:analyze": "npm run build && npm run analyze:build",
    "preview": "vite preview",
    "serve:dist": "node tools/serve-dist.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:compat": "playwright test --config=playwright.compat.config.ts",
    "test:static": "playwright test --config=playwright.static.config.ts",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build && npm run analyze:build",
    "validate:release": "npm run validate && npm run test:e2e && npm run test:compat && npm run test:static",
    "validate:generated-assets": "npm run assets:check"
  },
  "dependencies": {
    "@babylonjs/core": "9.16.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "esbuild": "0.28.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "fast-check": "4.9.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
